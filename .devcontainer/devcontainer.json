{
	"name": "squad-layer-manager",
	"build": {
		"dockerfile": "Dockerfile",
		// the image copies nothing from the repo (the workspace is bind-mounted, and the install happens
		// in post-create), so the context is this directory rather than the repo root -- data/ alone is
		// several GB to hand to the daemon for nothing
		"context": "."
	},
	"remoteUser": "node",

	"features": {
		// sudo for the node user (post-create needs it to take ownership of the volumes below), plus the
		// usual shell niceties
		"ghcr.io/devcontainers/features/common-utils:2": {
			"username": "node",
			"installZsh": false,
			"upgradePackages": false
		},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},

	"mounts": [
		// node_modules is a volume rather than part of the bind mount on purpose: the native deps
		// (better-sqlite3, cpu-features, bufferutil) are compiled against the host's glibc, and a tree
		// built on the host will not load in here. The container keeps its own install; the host keeps
		// its own.
		"source=slm-node-modules,target=${containerWorkspaceFolder}/node_modules,type=volume",
		// so a rebuild installs from the store instead of re-downloading the world. The path is pinned by
		// NPM_CONFIG_STORE_DIR in the Dockerfile; see the comment there for why it can't be the default.
		"source=slm-pnpm-store,target=/pnpm/store,type=volume"
	],

	// NOTE: these win over .env. The app reads process.env first and dotenv does not overwrite what is
	// already set (see src/server/env.ts ensureEnvSetup), so anything set here cannot be overridden from
	// .env -- only by the shell you launch the process in.
	"containerEnv": {
		// the app defaults to 127.0.0.1, which is unreachable from the host once it's inside a container
		"HOST": "0.0.0.0",
		// the otel stack (`docker compose up -d otel`) runs on the host, not in here
		"OTLP_COLLECTOR_ENDPOINT": "http://host.docker.internal:4318",
		// the repo's tools (dprint, oxlint, vitest, playwright, drizzle-kit) are devDependencies, and nothing
		// puts them on PATH outside of `pnpm run`. The container has no global copy of any of them to fall
		// back on the way a host does, so without this they are simply missing from every terminal in here.
		"PATH": "${containerWorkspaceFolder}/node_modules/.bin:${containerEnv:PATH}"
	},
	// makes host.docker.internal above resolve on Linux
	"runArgs": ["--add-host=host.docker.internal:host-gateway"],

	// published 1:1 (docker -p), so the host port is always the port in the label. appPort rather than
	// forwardPorts because forwardPorts is an editor-level tunnel that only VS Code implements -- Zed
	// drives the reference devcontainer CLI, which passes appPort to docker and ignores forwardPorts.
	// The bind happens when the container starts, so the container will not come up if something on the
	// host is already holding one of these (an app you left running outside the container, typically).
	"appPort": ["5173:5173", "3000:3000", "8443:8443", "9229:9229"],
	"portsAttributes": {
		"5173": { "label": "client (vite)" },
		"3000": { "label": "server (fastify)" },
		"8443": { "label": "squad logs receiver" },
		"9229": { "label": "node inspector" }
	},

	"postCreateCommand": "bash .devcontainer/post-create.sh",

	"customizations": {
		// only the languages the repo actually contains that Zed does not handle out of the box. Everything
		// else it needs (typescript, tailwind, the dprint formatter and the oxc lsp) is either built in or
		// configured in .zed/settings.json, which rides along in the bind mount.
		// NOTE: these install into your local Zed too, not just the container's session.
		"zed": {
			"extensions": ["dockerfile", "sql", "html"]
		},
		"vscode": {
			"extensions": [
				"dprint.dprint",
				"oxc.oxc-vscode",
				"bradlc.vscode-tailwindcss",
				"ms-playwright.playwright",
				"vitest.explorer"
			],
			"settings": {
				// the repo is on a typescript prerelease; VS Code has to be pointed at it explicitly
				"typescript.tsdk": "node_modules/typescript/lib",
				"editor.defaultFormatter": "dprint.dprint",
				"editor.formatOnSave": true,
				// the container's login shell is bash and scripts here assume it; fish is installed if you
				// want it, but it isn't the default
				"terminal.integrated.defaultProfile.linux": "bash"
			}
		}
	}
}
