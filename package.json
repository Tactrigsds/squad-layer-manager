{
	"name": "squad-layer-manager",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@10.22.0",
	"scripts": {
		"client:dev": "vite",
		"lint": "oxlint --type-aware",
		"lint:fix": "oxlint --type-aware --fix-suggestions --fix-dangerously",
		"preview": "vite preview",
		"check": "tsc -b",
		"format": "dprint fmt",
		"format:check": "dprint check",
		"test": "vitest run",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"build:client": "vite build",
		"build:server": "rolldown build -c rolldown-server-prod.config.ts",
		"build:prod": "pnpm run build:client && pnpm run build:server",
		"server:prod": "NODE_ENV=production node --enable-source-maps --import ./register-otel.mjs dist-server/main-instrumented.js",
		"server:dev": "NODE_ENV=development NODE_OPTIONS=\"--import ./register-otel.mjs\" tsx watch --inspect --include=./slm-config.jsonc --include=./.env --tsconfig tsconfig.node.json src/server/main-instrumented.ts",
		"__dev-instance:comment__": "many worktrees side by side: `dev:init` provisions one (port slot, env links, db clone), then `dev:emu` + `dev` run it. See docs/DEV_INSTANCES.md",
		"dev": "tsx --tsconfig tsconfig.node.json src/scripts/dev.ts",
		"dev:init": "tsx --tsconfig tsconfig.node.json src/scripts/dev-init.ts",
		"dev:emu": "tsx --tsconfig tsconfig.node.json src/scripts/dev-emu.ts",
		"emuctl": "tsx --tsconfig tsconfig.node.json src/scripts/dev-emuctl.ts",
		"dev:db:clone": "tsx --tsconfig tsconfig.node.json src/scripts/dev-clone-db.ts",
		"dev:slots": "tsx --tsconfig tsconfig.node.json src/scripts/dev-slots.ts",
		"__run-script:comment__": "run a script, just specify the script path as the last arg aka pnpm run run-script ./src/scripts/my-script.ts",
		"script": "tsx --tsconfig tsconfig.node.json",
		"preprocess": "LOG_LEVEL_OVERRIDE=info tsx --tsconfig tsconfig.node.json src/scripts/preprocess.ts",
		"preprocess:prod": "LOG_LEVEL_OVERRIDE=info node --enable-source-maps dist-server/scripts/preprocess.js",
		"check-layer-compat": "tsx --tsconfig tsconfig.node.json src/scripts/check-layer-compat.ts ./broken-layers.csv",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx --tsconfig tsconfig.node.json src/scripts/migrate.ts",
		"db:migrate:prod": "node --enable-source-maps dist-server/scripts/migrate.js",
		"setup:hooks": "git config core.hooksPath .githooks && chmod +x .githooks/pre-push .githooks/pre-push.js",
		"remove:hooks": "git config --unset core.hooksPath",
		"test:e2e": "pnpm run build:engine && NODE_ENV=production vite build && playwright test",
		"test:e2e:ci": "playwright test",
		"test:ci": "pnpm run test:integration && pnpm run test:e2e:ci",
		"build:engine": "cd layer-engine && cargo build --release --target wasm32-unknown-unknown && cd .. && mkdir -p assets && cp layer-engine/target/wasm32-unknown-unknown/release/layer_engine.wasm assets/layer-engine.wasm",
		"build:agent": "cargo build --release --manifest-path server-agent/agent/Cargo.toml",
		"build:all": "pnpm run build:engine && pnpm run build:prod"
	},
