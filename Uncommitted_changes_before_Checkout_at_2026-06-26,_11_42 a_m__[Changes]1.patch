+function watchLocalLogFile(filePath: string) {
+  return new Rx.Observable<string>((subscriber) => {
+    let position = 0;
+    let watcher: fs.FSWatcher | null = null;
+    let closed = false;
+    let reading = false;
+    let queuedRead = false;
+
+    const readNewChunks = async () => {
+      if (reading) {
+        queuedRead = true;
+        return;
+      }
+      reading = true;
+      try {
+        while (!closed) {
+          queuedRead = false;
+          const stats = await fs.promises
+            .stat(filePath)
+            .catch((err: NodeJS.ErrnoException) => {
+              if (err.code === "ENOENT") return null;
+              throw err;
+            });
+          if (!stats) break;
+          if (stats.size < position) position = 0;
+          if (stats.size === position) break;
+
+          const stream = fs.createReadStream(filePath, {
+            encoding: "utf8",
+            start: position,
+            end: stats.size - 1,
+          });
+          let chunk = "";
+          for await (const part of stream) {
+            chunk += part as string;
+          }
+          position = stats.size;
+          if (chunk.length > 0) subscriber.next(chunk);
+          if (!queuedRead) break;
+        }
+      } catch (error) {
+        subscriber.error(error);
+      } finally {
+        reading = false;
+      }
+    };
+
+    void fs.promises
+      .stat(filePath)
+      .then((stats) => {
+        position = stats.size;
+      })
+      .catch((err: NodeJS.ErrnoException) => {
+        if (err.code !== "ENOENT") throw err;
+      })
+      .then(() => {
+        if (closed) return;
+        watcher = fs.watch(filePath, () => {
+          void readNewChunks();
+        });
+        // Catch writes that landed after the initial stat() but before the watcher attached.
+        void readNewChunks();
+      })
+      .catch((error) => subscriber.error(error));
+
+    return () => {
+      closed = true;
+      watcher?.close();
+    };
+  });
 }
 
