{
	"uid": "slm-overview",
	"title": "SLM / Overview",
	"description": "Domain health for Squad Layer Manager: rcon liveness, queue depth, votes, teamswitches, and recent problems. Backed by the observable gauges registered in src/systems/metrics.server.ts.",
	"tags": ["slm"],
	"timezone": "browser",
	"editable": true,
	"schemaVersion": 39,
	"refresh": "30s",
	"time": { "from": "now-6h", "to": "now" },
	"templating": {
		"list": [
			{
				"name": "server",
				"label": "Squad server",
				"type": "query",
				"datasource": { "type": "prometheus", "uid": "prometheus" },
				"query": "label_values(slm_rcon_connected, slm_squad_server_id)",
				"refresh": 2,
				"includeAll": true,
				"multi": true,
				"current": { "text": "All", "value": "$__all" }
			}
		]
	},
	"panels": [
		{
			"type": "row",
			"title": "Liveness",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
		},
		{
			"type": "stat",
			"title": "RCON connected",
			"description": "0 means the rcon socket to that squad server is down. This is the single most important signal here: almost every other SLM function depends on it.",
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"gridPos": { "h": 5, "w": 8, "x": 0, "y": 1 },
			"targets": [
				{
					"refId": "A",
					"expr": "slm_rcon_connected{slm_squad_server_id=~\"$server\"}",
					"legendFormat": "{{slm_squad_server_id}}"
				}
			],
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
				"colorMode": "background",
				"graphMode": "area",
				"textMode": "auto"
			},
			"fieldConfig": {
				"defaults": {
					"mappings": [
						{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red", "index": 0 } } },
						{ "type": "value", "options": { "1": { "text": "UP", "color": "green", "index": 1 } } }
					],
					"thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
				},
				"overrides": []
			}
		},
		{
			"type": "stat",
			"title": "Connected clients",
			"description": "Live websocket sessions (slm.websocket.connected_clients).",
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
			"targets": [{ "refId": "A", "expr": "slm_websocket_connected_clients", "legendFormat": "clients" }],
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
				"colorMode": "value",
				"graphMode": "area"
			},
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "thresholds" },
					"thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
				},
				"overrides": []
			}
		},
		{
			"type": "stat",
			"title": "Server slices",
			"description": "Number of initialized squad server slices (slm.squad_server.count). A drop here without a config change means a slice failed to come up.",
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
			"targets": [{ "refId": "A", "expr": "slm_squad_server_count", "legendFormat": "slices" }],
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
				"colorMode": "value",
				"graphMode": "area"
			},
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "thresholds" },
					"thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
				},
				"overrides": []
			}
		},
		{
			"type": "timeseries",
			"title": "RCON uptime",
			"description": "Same signal over time. Flapping shows up here as a square wave.",
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"gridPos": { "h": 5, "w": 8, "x": 16, "y": 1 },
			"targets": [
				{
					"refId": "A",
					"expr": "slm_rcon_connected{slm_squad_server_id=~\"$server\"}",
					"legendFormat": "{{slm_squad_server_id}}"
				}
			],
			"fieldConfig": {
				"defaults": {
					"min": 0,
					"max": 1,
					"custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 20, "lineWidth": 2 }
				},
				"overrides": []
			}
		},
		{
			"type": "row",
			"title": "Queue and votes",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }
		},
		{
			"type": "timeseries",
			"title": "Layer queue length",
			"description": "Items in the live (in-edit) layer queue per server. A queue draining toward 0 without being refilled is worth an alert.",
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
			"targets": [
				{
					"refId": "A",
					"expr": "slm_layer_queue_length{slm_squad_server_id=~\"$server\"}",
					"legendFormat": "{{slm_squad_server_id}}"
				}
			],
			"fieldConfig": {
				"defaults": { "min": 0, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10, "lineWidth": 2 } },
				"overrides": []
			}
		},
		{
			"type": "timeseries",
			"title": "Votes in progress / unsaved queue edits",
			"description": "slm.vote.in_progress and slm.layer_queue.unsaved. An unsaved queue that stays at 1 for a long time means an edit session was abandoned mid-flight.",
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
			"targets": [
				{
					"refId": "A",
					"expr": "slm_vote_in_progress{slm_squad_server_id=~\"$server\"}",
					"legendFormat": "vote {{slm_squad_server_id}}"
				},
				{
					"refId": "B",
					"expr": "slm_layer_queue_unsaved{slm_squad_server_id=~\"$server\"}",
					"legendFormat": "unsaved {{slm_squad_server_id}}"
				}
			],
			"fieldConfig": {
				"defaults": {
					"min": 0,
					"max": 1,
					"custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 20, "lineWidth": 2 }
				},
				"overrides": []
			}
		},
		{
			"type": "row",
			"title": "Teamswitches and BattleMetrics",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
		},
		{
			"type": "timeseries",
			"title": "Pending team switches",
			"description": "Switches saved and waiting to execute (slm.teamswitch.pending_switches), with the in-flight flag overlaid.",
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
			"targets": [
				{
					"refId": "A",
					"expr": "slm_teamswitch_pending_switches{slm_squad_server_id=~\"$server\"}",
					"legendFormat": "pending {{slm_squad_server_id}}"
				},
				{
					"refId": "B",
					"expr": "slm_teamswitch_switching{slm_squad_server_id=~\"$server\"}",
					"legendFormat": "switching {{slm_squad_server_id}}"
				}
			],
			"fieldConfig": {
				"defaults": { "min": 0, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10, "lineWidth": 2 } },
				"overrides": []
			}
		},
		{
			"type": "timeseries",
			"title": "BattleMetrics rate limit",
			"description": "Requests in the last 1s/60s window and the queue depth waiting on the limiter. A persistently non-zero queue means we are being shaped by BM's limits.",
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
			"targets": [
				{ "refId": "A", "expr": "battlemetrics_rate_limit_per_second", "legendFormat": "req/1s (limit 10)" },
				{ "refId": "B", "expr": "battlemetrics_rate_limit_per_minute", "legendFormat": "req/60s (limit 60)" },
				{ "refId": "C", "expr": "battlemetrics_rate_limit_queue_size", "legendFormat": "queued" }
			],
			"fieldConfig": {
				"defaults": { "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } },
				"overrides": []
			}
		},
		{
			"type": "row",
			"title": "Recent problems",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
		},
		{
			"type": "logs",
			"title": "Warnings and errors",
			"description": "Every line here carries trace_id in its structured metadata, so the Loki derived field links straight through to the Tempo trace that produced it.",
			"datasource": { "type": "loki", "uid": "loki" },
			"gridPos": { "h": 11, "w": 24, "x": 0, "y": 23 },
			"targets": [
				{
					"refId": "A",
					"expr": "{service_name=\"squad-layer-manager\"} | severity_text =~ `WARN|ERROR|FATAL`",
					"queryType": "range"
				}
			],
			"options": {
				"showTime": true,
				"showLabels": false,
				"showCommonLabels": false,
				"wrapLogMessage": true,
				"prettifyLogMessage": false,
				"enableLogDetails": true,
				"dedupStrategy": "none",
				"sortOrder": "Descending"
			}
		}
	]
}
