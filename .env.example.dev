# ---- General -----------------------------------------------------------------------------------------------
# `pnpm server:dev` sets this itself; it is only read from here by bare `pnpm script` / `pnpm preprocess` runs.
NODE_ENV=development

# overrides the log level, which is otherwise debug in development and test, info in production.
# LOG_LEVEL_OVERRIDE=

# lets a request log in as an existing user with a `?login=<username>` query param, skipping discord oauth.
# Rejected when NODE_ENV=production.
# QUERY_PARAM_AUTH_BYPASS=

# comma-separated context params to leave out of rendered log lines. Does not affect exported logs.
# LOG_EXCLUDE_CONTEXT_PARAMS=

# the file credentials are read from. Defaults to ./.env.secrets when it exists; set this to read them from
# somewhere else (e.g. /run/secrets/slm-secrets, where a docker secret is mounted). A path that does not exist
# is an error.
# SECRETS_FILE=

# shown to users in the app. Set these to your fork if you run one.
# PUBLIC_REPO_URL=

# where the app points users who want to report a bug.
# PUBLIC_ISSUES_URL=

# ---- Squadcalc ---------------------------------------------------------------------------------------------
# the squadcalc instance the layer info popouts link out to. Only set it if you self-host squadcalc.
# PUBLIC_SQUADCALC_URL=https://squadcalc.app

# ---- Telemetry ---------------------------------------------------------------------------------------------
# turn it off if nothing is listening on the endpoint below.
# OTEL_ENABLED=true

# where the exporters send to. docker-compose points this at its own collector service.
# OTLP_COLLECTOR_ENDPOINT=http://localhost:4318

# the fraction of traces sampled. 1 keeps everything.
# OTEL_TRACE_SAMPLE_RATIO=1

# ---- Permissions -------------------------------------------------------------------------------------------
# comma-separated discord user ids granted every permission (e.g. 123456789012345678,987654321098765432). Set at
# least one, or nobody can administer the app. Every other role is configured from the settings page.
SUPER_USERS=

# as SUPER_USERS, but discord role ids: everyone holding one of these roles is granted every permission.
# SUPER_ROLES=

# ---- Encryption --------------------------------------------------------------------------------------------
# the key sensitive settings are encrypted at rest with. The value below is the public dev key; the app refuses
# to start with it when NODE_ENV=production. Generate a real one with `openssl rand -base64 32`.
SETTINGS_ENCRYPTION_KEY=A_VERY_INSECURE_ENCRYPTION_KEY

# ---- Database ----------------------------------------------------------------------------------------------
# the main sqlite database. -wal and -shm files are created alongside it, so mount the directory, not the file.
# DB_PATH=./data/db.sqlite3

# applies pending migrations at boot. Turn it off to run them yourself (`pnpm db:migrate`); the app then refuses
# to start against a database that is behind.
# DB_AUTOMIGRATE=true

# ---- Discord -----------------------------------------------------------------------------------------------
# disables the discord integration entirely (no bot login, no guild fetches). The integration tests and the
# emulator run with it off; the other DISCORD_* vars still need dummy values.
# DISCORD_ENABLED=true

# from the discord app SLM logs users in with.
DISCORD_CLIENT_ID=

# the discord app's oauth2 client secret.
DISCORD_CLIENT_SECRET=

# the bot token of the same discord app. The bot has to be installed on the guild DISCORD_HOME_GUILD_ID names.
DISCORD_BOT_TOKEN=

# the guild SLM resolves users and roles against, i.e. your org's discord server.
DISCORD_HOME_GUILD_ID=

# ---- HTTP server -------------------------------------------------------------------------------------------
# the port the app listens on. The client is served separately in development, see CLIENT_PORT.
# PORT=3000

# the interface the app binds to.
# HOST=127.0.0.1

# the vite dev server's port. Move it to run a second instance beside a running one; ORIGIN has to move with it.
# CLIENT_PORT=5173

# the url the app is reached at, from a browser's point of view. In development that is the vite dev server
# (CLIENT_PORT), which serves the client, not the app's own port. The discord oauth callback is built from this,
# so it also has to match a redirect uri registered on the discord app.
ORIGIN=http://localhost:5173

# ---- Layers ------------------------------------------------------------------------------------------------
# @latest resolves to the highest version whose artifacts are present. Pinning a version no searched directory
# has is an error.
# LAYERS_VERSION=@latest

# an extra directory to search for layer artifacts, ahead of ./data and the assets/layers the image ships. Only
# needed when the artifacts live outside the data mount.
# LAYERS_DIR=

# ---- Preprocess --------------------------------------------------------------------------------------------
# OWI's layer spreadsheet. Only used for layer sizes at the moment.
# SPREADSHEET_ID=1UXEgkUMBxhmYyEkaMSUd1Ko_I7s--7krCdyshZ076pU

# the sheet within SPREADSHEET_ID the layers are read from.
# SPREADSHEET_MAP_LAYERS_GID=1212962563

# the csv preprocess ingests, and where a build takes its version from. Too big to ship, so it stays in ./data.
# EXTRA_COLS_CSV_PATH=./data/layers_v{{LAYERS_VERSION}}.csv

# where preprocess writes the pair it builds. Defaults to the directory that ships with the image.
# LAYERS_OUTPUT_DIR=./assets/layers

# defines the extra columns to ingest into the layer table. Read only by preprocess, which bakes the definitions
# into layer-data.json.
# LAYER_DB_CONFIG_PATH=./layer-db.json

# ---- Battlemetrics -----------------------------------------------------------------------------------------
# the battlemetrics api.
# BM_HOST=https://api.battlemetrics.com

# battlemetrics API token. It needs these permissions:
# - player flags (add/remove; it does not need to create new ones)
# - player notes (read & create)
# - rcon (read)
# Leave it empty if you have no battlemetrics org: the app boots without it, and the features that read it fail.
BM_PAT=

# the battlemetrics organization BM_PAT belongs to. Player flags are filtered to this org.
BM_ORG_ID=
