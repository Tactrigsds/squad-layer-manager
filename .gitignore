# Editor directories and files
.vscode/*
!.vscode/extensions.json
# settings.json and debug.json are project config (formatter, language servers, debug targets) and are
# tracked; anything else that lands in here, adminlist.txt included, is local scratch
.zed/*
!.zed/settings.json
!.zed/debug.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.tsbuildinfo
.env*
# generated from src/server/env.ts on every dev boot, and tracked: the templates an install and a checkout
# respectively start from
!.env.example
!.env.example.dev

slm-config.json*
extra-columns.json
google-credentials.json

/data/layers*.csv
# the layer artifacts ship in assets/layers (tracked). ./data is only ever a local/deployment override, so
# anything dropped in there stays out of the repo.
/data/layers_v*.bin
/data/layers_v*.bin.gz
/data/layer-data_v*.json

# preprocess writes the table twice: compressed (tracked, and what the image ships) and uncompressed. The
# engine loads either, the uncompressed one just loads quicker, and at 60MB it has no business in git.
/assets/layers/layers_v*.bin

broken-layers.csv
drizzle/seed_weights.sql

layer-db.json

certs/
.million/
docker/logs
docker/squad-dedicated

.tanstack/
.claude/

dist-server/

graph.svg

