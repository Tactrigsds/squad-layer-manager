{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {"type": "string"},
    "homeDiscordGuildId": {
      "description": "A string representation of a big integer that is parsed to a BigInt",
      "type": "string",
      "pattern": "^-?\\d+$"
    },
    "repoUrl": {
      "description": "URL of the repository",
      "type": "string",
      "format": "uri"
    },
    "issuesUrl": {
      "description": "URL of the issues page",
      "type": "string",
      "format": "uri"
    },
    "globalRolePermissions": {
      "description": "Configures what roles have what permissions. (globally scoped permissions only)",
      "type": "object",
      "propertyNames": {"type": "string"},
      "additionalProperties": {
        "type": "array",
        "items": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "site:authorized",
                "queue:write",
                "queue:force-write",
                "settings:write",
                "vote:manage",
                "filters:write-all",
                "squad-server:end-match",
                "squad-server:disable-slm-updates",
                "squad-server:turn-fog-off",
                "squad-server:manage-players",
                "squad-server:warn-players",
                "battlemetrics:write-flags",
                "admin:manage-servers",
                "admin:delete-servers",
                "admin:manage-global-settings",
                "admin:restart-slm"
              ]
            },
            {"description": "include all", "type": "string", "const": "*"},
            {
              "description": "negated permissions. takes precedence wherever present for a user",
              "type": "string",
              "pattern": "^!"
            }
          ]
        }
      }
    },
    "roleAssignments": {
      "type": "object",
      "properties": {
        "discord-role": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "discordRoleId": {
                "description": "A string representation of a big integer that is parsed to a BigInt",
                "type": "string",
                "pattern": "^-?\\d+$"
              },
              "roles": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 32,
                  "pattern": "^[a-z0-9-]+$"
                }
              }
            },
            "required": ["discordRoleId", "roles"]
          }
        },
        "discord-user": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "userId": {
                "description": "A string representation of a big integer that is parsed to a BigInt",
                "type": "string",
                "pattern": "^-?\\d+$"
              },
              "roles": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 32,
                  "pattern": "^[a-z0-9-]+$"
                }
              }
            },
            "required": ["userId", "roles"]
          }
        },
        "discord-server-member": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "roles": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 32,
                  "pattern": "^[a-z0-9-]+$"
                }
              }
            },
            "required": ["roles"]
          }
        }
      }
    },
    "layerTable": {
      "default": {
        "orderedColumns": [
          {"name": "id", "visible": false},
          {"name": "Size"},
          {"name": "Layer"},
          {"name": "Map", "visible": false},
          {"name": "Gamemode", "visible": false},
          {"name": "LayerVersion", "visible": false},
          {"name": "Faction_1"},
          {"name": "Unit_1"},
          {"name": "Alliance_1", "visible": false},
          {"name": "Faction_2"},
          {"name": "Unit_2"},
          {"name": "Alliance_2", "visible": false}
        ],
        "defaultSortBy": {"type": "random"}
      },
      "type": "object",
      "properties": {
        "orderedColumns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "visible": {"description": "default true", "type": "boolean"}
            },
            "required": ["name"]
          }
        },
        "defaultSortBy": {
          "description": "if not provided, no sorting will be done",
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "type": {"type": "string", "const": "column"},
                "sortBy": {"type": "string"},
                "direction": {
                  "default": "ASC",
                  "type": "string",
                  "enum": ["ASC", "DESC", "ASC:ABS", "DESC:ABS"]
                }
              },
              "required": ["type", "sortBy"]
            },
            {
              "type": "object",
              "properties": {
                "type": {"type": "string", "const": "random"},
                "seed": {"type": "string"}
              },
              "required": ["type"]
            }
          ]
        },
        "extraLayerSelectMenuItems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "column": {"type": "string"},
              "code": {
                "type": "string",
                "enum": [
                  "lt",
                  "gt",
                  "inrange",
                  "isnull",
                  "notnull",
                  "in",
                  "notin",
                  "eq",
                  "neq",
                  "is-true"
                ]
              },
              "value": {
                "anyOf": [
                  {"type": "number"},
                  {"type": "string"},
                  {"type": "null"}
                ]
              },
              "values": {
                "type": "array",
                "items": {"anyOf": [{"type": "string"}, {"type": "null"}]}
              },
              "range": {
                "type": "array",
                "prefixItems": [{"type": "number"}, {"type": "number"}]
              },
              "allMasks": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "alliance": {
                        "anyOf": [
                          {"type": "array", "items": {"type": "string"}},
                          {"type": "null"}
                        ]
                      },
                      "faction": {
                        "anyOf": [
                          {"type": "array", "items": {"type": "string"}},
                          {"type": "null"}
                        ]
                      },
                      "unit": {
                        "anyOf": [
                          {"type": "array", "items": {"type": "string"}},
                          {"type": "null"}
                        ]
                      }
                    }
                  }
                }
              },
              "mode": {"type": "string", "enum": ["split", "both", "either"]}
            }
          }
        },
        "defaultExtraFilters": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 64,
            "pattern": "^[a-z0-9-_]+$"
          }
        }
      },
      "required": ["orderedColumns", "defaultSortBy"]
    }
  },
  "required": ["homeDiscordGuildId", "globalRolePermissions", "roleAssignments"]
}