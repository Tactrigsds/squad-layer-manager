{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {"type": "string"},
    "homeDiscordGuildId": {
      "description": "A string representation of a big integer that is parsed to a BigInt",
      "type": "string",
      "pattern": "^-?\\d+$"
    },
    "repoUrl": {
      "description": "URL of the repository",
      "type": "string",
      "format": "uri"
    },
    "issuesUrl": {
      "description": "URL of the issues page",
      "type": "string",
      "format": "uri"
    },
    "superUsers": {
      "description": "Discord user ids that are always granted all permissions",
      "default": [],
      "type": "array",
      "items": {
        "description": "A string representation of a big integer that is parsed to a BigInt",
        "type": "string",
        "pattern": "^-?\\d+$"
      }
    },
    "superRoles": {
      "description": "Discord role ids whose members are always granted all permissions",
      "default": [],
      "type": "array",
      "items": {
        "description": "A string representation of a big integer that is parsed to a BigInt",
        "type": "string",
        "pattern": "^-?\\d+$"
      }
    },
    "layerTable": {
      "default": {
        "orderedColumns": [
          {"name": "id", "visible": false},
          {"name": "Size"},
          {"name": "Layer"},
          {"name": "Map", "visible": false},
          {"name": "Gamemode", "visible": false},
          {"name": "LayerVersion", "visible": false},
          {"name": "Faction_1"},
          {"name": "Unit_1"},
          {"name": "Alliance_1", "visible": false},
          {"name": "Faction_2"},
          {"name": "Unit_2"},
          {"name": "Alliance_2", "visible": false}
        ],
        "defaultSortBy": {"type": "random"}
      },
      "type": "object",
      "properties": {
        "orderedColumns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "visible": {"description": "default true", "type": "boolean"}
            },
            "required": ["name"]
          }
        },
        "defaultSortBy": {
          "description": "if not provided, no sorting will be done",
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "type": {"type": "string", "const": "column"},
                "sortBy": {"type": "string"},
                "direction": {
                  "default": "ASC",
                  "type": "string",
                  "enum": ["ASC", "DESC", "ASC:ABS", "DESC:ABS"]
                }
              },
              "required": ["type", "sortBy"]
            },
            {
              "type": "object",
              "properties": {
                "type": {"type": "string", "const": "random"},
                "seed": {"type": "string"}
              },
              "required": ["type"]
            }
          ]
        },
        "extraLayerSelectMenuItems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["eq", "in", "lt", "gt", "inrange"]
              },
              "neg": {"type": "boolean"},
              "args": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "type": {"type": "string", "const": "column"},
                        "column": {"type": "string"}
                      },
                      "required": ["type"]
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {"type": "string", "const": "team-column"},
                        "column": {
                          "type": "string",
                          "enum": ["Alliance", "Faction", "Unit"]
                        },
                        "quantifier": {
                          "type": "string",
                          "enum": ["either", "both"]
                        }
                      },
                      "required": ["type"]
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {"type": "string", "const": "value"},
                        "value": {
                          "anyOf": [
                            {"type": "string"},
                            {"type": "number"},
                            {"type": "boolean"},
                            {"type": "null"}
                          ]
                        }
                      },
                      "required": ["type"]
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {"type": "string", "const": "values"},
                        "values": {
                          "type": "array",
                          "items": {
                            "anyOf": [
                              {
                                "anyOf": [
                                  {"type": "string"},
                                  {"type": "number"},
                                  {"type": "boolean"},
                                  {"type": "null"}
                                ]
                              },
                              {
                                "type": "object",
                                "properties": {
                                  "type": {"type": "string", "const": "column"},
                                  "column": {"type": "string"}
                                },
                                "required": ["type", "column"]
                              }
                            ]
                          }
                        }
                      },
                      "required": ["type"]
                    }
                  ]
                }
              }
            },
            "required": ["type", "args"]
          }
        },
        "defaultExtraFilters": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 64,
            "pattern": "^[a-z0-9-_]+$"
          }
        }
      },
      "required": ["orderedColumns", "defaultSortBy"]
    }
  },
  "required": ["homeDiscordGuildId"]
}