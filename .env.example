# The environment SLM runs on, minus the credentials, which go in .env.secrets (see .env.secrets.example).
#
# Fill in the vars left uncommented. Commented-out vars are optional and show their default.

# ---- General -----------------------------------------------------------------------------------------------
# overrides the log level, which is otherwise info.
# LOG_LEVEL_OVERRIDE=

# the file credentials are read from. Defaults to ./.env.secrets when it exists; set this to read them from
# somewhere else (e.g. /run/secrets/slm-secrets, where a docker secret is mounted). A path that does not exist
# is an error.
# SECRETS_FILE=

# ---- Squadcalc ---------------------------------------------------------------------------------------------
# the squadcalc instance the layer info popouts link out to. Only set it if you self-host squadcalc.
# PUBLIC_SQUADCALC_URL=https://squadcalc.app

# ---- Telemetry ---------------------------------------------------------------------------------------------
# the app exports traces, metrics and logs over OTLP. docker-compose runs a grafana/otel-lgtm collector next to
# it, which serves the dashboards.

# turn it off if nothing is listening on the endpoint below.
# OTEL_ENABLED=true

# where the exporters send to. docker-compose points this at its own collector service.
# OTLP_COLLECTOR_ENDPOINT=http://localhost:4318

# the fraction of traces sampled. 1 keeps everything.
# OTEL_TRACE_SAMPLE_RATIO=1

# ---- Profiling ---------------------------------------------------------------------------------------------
# continuous CPU and heap profiles pushed to the Pyroscope bundled in the otel-lgtm collector. Off by default;
# view the flamegraphs under Grafana's Pyroscope datasource.

# push continuous profiles to a Pyroscope server (bundled in the otel-lgtm image). View them under Grafana's
# Pyroscope datasource. Adds a few percent of runtime overhead.
# PYROSCOPE_ENABLED=false

# where profiles are pushed. docker-compose points this at its own otel service (http://otel:4040).
# PYROSCOPE_ENDPOINT=http://localhost:4040

# also sample allocations and in-use heap, not just CPU/wall. Its overhead scales with allocation rate; turn it
# off to keep only the flatter-cost CPU profiles.
# PYROSCOPE_HEAP_ENABLED=true

# ---- Permissions -------------------------------------------------------------------------------------------
# comma-separated discord user ids granted every permission (e.g. 123456789012345678,987654321098765432). Set at
# least one, or nobody can administer the app. Every other role is configured from the settings page.
SUPER_USERS=

# as SUPER_USERS, but discord role ids: everyone holding one of these roles is granted every permission.
# SUPER_ROLES=

# ---- Database ----------------------------------------------------------------------------------------------
# the main sqlite database. -wal and -shm files are created alongside it, so mount the directory, not the file.
# DB_PATH=./data/db.sqlite3

# applies pending migrations at boot. Turn it off to run them yourself (`pnpm db:migrate:prod`); the app then
# refuses to start against a database that is behind.
# DB_AUTOMIGRATE=true

# ---- Backups -----------------------------------------------------------------------------------------------
# how often to back up the main db, as a duration (e.g. 72h). Unset disables automatic backups, including the
# event-history prune that runs alongside them.
# AUTOMATIC_BACKUPS_PERIODIC=

# where backups are written locally.
# BACKUPS_DIR=./data/backups

# how many backups to keep, locally and on the sftp target. 0 keeps all of them. Periodic and pre-migration
# backups share this one window; the most recent pre-migration backup is always kept, however old.
# BACKUPS_RETAIN_COUNT=10

# server events from matches that ended longer ago than this duration (e.g. 90d) are deleted before each backup
# is taken. The most recent matches are always kept. Unset disables pruning.
# EVENT_HISTORY_RETENTION_PERIOD=

# an sftp target each backup is uploaded to after it is written locally. Setting this host enables the upload; a
# password or a private key is also required.
# BACKUP_SFTP_HOST=

# see BACKUP_SFTP_HOST.
# BACKUP_SFTP_PORT=22

# see BACKUP_SFTP_HOST.
# BACKUP_SFTP_USERNAME=

# see BACKUP_SFTP_HOST. Either this or BACKUP_SFTP_PASSWORD is required once a host is set.
# BACKUP_SFTP_PRIVATE_KEY_PATH=

# the remote directory backups are written to. Created if it does not exist.
# BACKUP_SFTP_DIR=.

# ---- Discord -----------------------------------------------------------------------------------------------
# SLM authenticates users through a discord app you own.

# from the discord app SLM logs users in with.
DISCORD_CLIENT_ID=

# the guild SLM resolves users and roles against, i.e. your org's discord server.
DISCORD_HOME_GUILD_ID=

# ---- HTTP server -------------------------------------------------------------------------------------------
# the port the app listens on. Put your reverse proxy in front of it and point ORIGIN at that.
# PORT=3000

# the interface the app binds to. The image already sets 0.0.0.0, since loopback inside a container is
# unreachable.
# HOST=127.0.0.1

# the publicly addressable url the app is reached at, from a browser's point of view. The default below only
# holds if the app is reached directly on PORT, with nothing in front of it. The discord oauth callback is built
# from this, so it also has to match a redirect uri registered on the discord app.
ORIGIN=http://localhost:3000

# ---- Layers ------------------------------------------------------------------------------------------------
# the app ships with a complete set of layer artifacts and boots without any of these set.

# @latest resolves to the highest version whose artifacts are present. Pinning a version no searched directory
# has is an error.
# LAYERS_VERSION=@latest

# an extra directory to search for layer artifacts, ahead of ./data and the assets/layers the image ships. Only
# needed when the artifacts live outside the data mount.
# LAYERS_DIR=

# ---- Battlemetrics -----------------------------------------------------------------------------------------
# the battlemetrics api.
# BM_HOST=https://api.battlemetrics.com

# the battlemetrics organization BM_PAT belongs to. Player flags are filtered to this org.
BM_ORG_ID=
