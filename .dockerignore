# Dependencies
/node_modules

# Git
/.git
/.github

# Build artifacts (will be created in builder stage)
/dist
/dist-server

# Development files
/.zed
/.idea
/.ropeproject
/.million
/certs
/data

# Environment and config (will be provided at runtime)
/.env
/.env.*
/config.json
/slm-config.json*
/layer-db.json

# Logs
/logs
*.log

# Test files: the `test` stage needs these (they never reach the production stages, which copy only
# build output), so only the artifacts that must stay out are excluded
/test-results
/playwright-report

# Documentation
/README.md
/docs
/todo.md

# The uncompressed layer table: preprocess leaves it beside the .gz, the image only ever ships the .gz, and at
# 60MB it would otherwise be dragged into the build context on every build.
/assets/layers/layers_v*.bin

# Temporary files
*.tmp
*.swp
*~
.DS_Store

# TypeScript build info
*.tsbuildinfo
